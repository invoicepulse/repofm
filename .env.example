# ElevenLabs API key — used for TTS, STT, and sound effects generation
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Groq API — used for LLM script generation (Llama 3.3 70B)
GROQ_API_KEY=your_groq_api_key_here

# GitIngest — self-hosted codebase ingestion service
GITINGEST_URL=your_GITINGEST_URL_here

# ElevenLabs Voice IDs — one per character
VOICE_ID_NARRATOR=your_narrator_voice_id_here
VOICE_ID_SKEPTIC=your_skeptic_voice_id_here
VOICE_ID_FAN=your_fan_voice_id_here
VOICE_ID_INTERN=your_intern_voice_id_here
